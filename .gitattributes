# Linux runtime files must remain LF even when the repository is checked out on Windows.
*.sh text eol=lf
*.service text eol=lf
*.json5 text eol=lf
*.xml text eol=lf

# Native Windows entry points use CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary acceptance evidence uses Git LFS.
screenshot/*.mp4 filter=lfs diff=lfs merge=lfs -text
screenshot/*.zip filter=lfs diff=lfs merge=lfs -text
