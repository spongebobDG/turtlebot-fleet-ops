{
  "plugins": {
    "ros2dds": {
      "nodename": "tb1_zenoh_bridge",
      "allow": {
        "publishers": [
          "^/fleet/robot_status$",
          "^/fleet/navigation_status$",
          "^/fleet/mapping_status$",
          "^/fleet/safety_status$",
          "^/fleet/rosout$",
          "^/fleet/web_telemetry$",
          "^/scan$",
          "^/scan_normalized$",
          "^/odom$",
          "^/tf$",
          "^/tf_static$",
          "^/robot_description$",
          "^/joint_states$",
          "^/map$",
          "^/map_metadata$",
          "^/amcl_pose$",
          "^/particle_cloud$",
          "^/plan$",
          "^/local_plan$",
          "^/local_costmap/.*",
          "^/global_costmap/.*"
        ],
        "subscribers": [
          "^/fleet/navigation_lease$"
        ],
        "service_servers": [
          "^/safety_watchdog/set_estop$",
          "^/tb1/navigation/set_initial_pose$",
          "^/tb1/navigation/set_motion_mode$"
          ,"^/tb1/navigation/manual_command$"
          ,"^/tb1/navigation/set_operating_profile$"
          ,"^/tb1/navigation/save_map$"
        ],
        "service_clients": [],
        "action_servers": [
          "^/tb1/navigation/navigate$"
        ],
        "action_clients": []
      },
      "pub_max_frequencies": [
        "^/fleet/rosout$=20",
        "^/scan$=5",
        "^/scan_normalized$=5",
        "^/tf$=30"
      ],
      "pub_priorities": [
        "^/fleet/robot_status$=1:express",
        "^/fleet/navigation_status$=1:express",
        "^/fleet/safety_status$=1:express",
        "^/fleet/web_telemetry$=1:express",
        "^/fleet/rosout$=5",
        "^/tf$=2",
        "^/scan_normalized$=1:express",
        "^/scan$=1:express"
      ]
    }
  }
}
